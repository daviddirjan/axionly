---
const { pathname } = Astro.url;
const isRo = pathname.startsWith('/ro');
const pfx  = isRo ? '/ro' : '';

const t = {
  en: {
    tagline:   'AI Governance & Security Consulting',
    division:  'A division of Axiontic',
    nav:       'Navigation',
    contact:   'Contact',
    badges:    'Assessment aligned with',
    pages:     ['Home', 'Services', 'How It Works', 'About', 'Resources', 'Contact'],
    linkedin:  'LinkedIn',
    location:  'Romania, European Union',
    copyright: `© ${new Date().getFullYear()} Axionly — a division of Axiontic. All rights reserved.`,
    privacy:   'Privacy Policy',
    cookies:   'Cookie Policy',
  },
  ro: {
    tagline:   'Consultanță în Guvernanță AI și Securitate',
    division:  'O divizie a Axiontic',
    nav:       'Navigare',
    contact:   'Contact',
    badges:    'Evaluare aliniată cu',
    pages:     ['Acasă', 'Servicii', 'Cum Funcționează', 'Despre Noi', 'Resurse', 'Contact'],
    linkedin:  'LinkedIn',
    location:  'România, Uniunea Europeană',
    copyright: `© ${new Date().getFullYear()} Axionly — o divizie a Axiontic. Toate drepturile rezervate.`,
    privacy:   'Politică de Confidențialitate',
    cookies:   'Politică Cookie',
  },
}[isRo ? 'ro' : 'en'];

const navSlugs = ['/', '/services', '/how-it-works', '/about', '/resources', '/contact'];
const navLinks = t.pages.map((label, i) => ({
  label,
  href: i === 0 ? (isRo ? '/ro' : '/') : pfx + navSlugs[i],
}));

const badges = ['EU AI Act', 'GDPR', 'ISO 42001'];
---

<footer>
  <div class="container footer-inner">

    <div class="col col-brand">
      <a href={isRo ? '/ro' : '/'} class="logo" aria-label="Axionly home">
        Axionly<span class="logo-dot">.</span>
      </a>
      <p class="tagline">{t.tagline}</p>
      <a href="https://axiontic.com" class="axiontic-link" target="_blank" rel="noopener">
        {t.division} →
      </a>
    </div>

    <div class="col">
      <p class="col-heading">{t.nav}</p>
      <nav aria-label="Footer navigation">
        <ul>
          {navLinks.map(link => (
            <li><a href={link.href}>{link.label}</a></li>
          ))}
        </ul>
      </nav>
    </div>

    <div class="col">
      <p class="col-heading">{t.contact}</p>
      <ul class="contact-list">
        <li><a href="mailto:hello@axionly.io">hello@axionly.io</a></li>
        <li><a href="https://linkedin.com" target="_blank" rel="noopener">{t.linkedin}</a></li>
        <li>{t.location}</li>
      </ul>
    </div>

    <div class="col">
      <p class="col-heading">{t.badges}</p>
      <ul class="badges">
        {badges.map(b => <li class="badge">{b}</li>)}
      </ul>
    </div>

  </div>

  <div class="footer-bottom">
    <div class="container footer-bottom-inner">
      <p>{t.copyright}</p>
      <div class="legal-links">
        <a href="#">{t.privacy}</a>
        <a href="#">{t.cookies}</a>
      </div>
    </div>
  </div>
</footer>

<style>
  footer { background-color: var(--color-text); color: var(--color-white); padding-top: 4rem; }

  .footer-inner {
    display: grid;
    grid-template-columns: 1.4fr 1fr 1fr 1fr;
    gap: 2.5rem;
    padding-bottom: 3.5rem;
    border-bottom: 1px solid rgba(255,255,255,0.08);
  }

  .col-brand { display: flex; flex-direction: column; gap: 0.6rem; }

  .logo { font-family: var(--font-logo); font-weight: 700; font-size: 1.5rem; letter-spacing: -0.04em; color: var(--color-white); }
  .logo-dot { color: var(--color-accent); }

  .tagline { font-size: 0.875rem; color: rgba(255,255,255,0.5); max-width: 200px; line-height: 1.5; }

  .axiontic-link { font-size: 0.8125rem; color: var(--color-accent); transition: opacity var(--transition); margin-top: 0.25rem; }
  .axiontic-link:hover { opacity: 0.8; }

  .col-heading { font-size: 0.75rem; font-weight: 700; letter-spacing: 0.08em; text-transform: uppercase; color: rgba(255,255,255,0.4); margin-bottom: 1rem; }

  nav ul, .contact-list, .badges { list-style: none; display: flex; flex-direction: column; gap: 0.5rem; }

  nav a, .contact-list a { font-size: 0.9rem; color: rgba(255,255,255,0.65); transition: color var(--transition); }
  nav a:hover, .contact-list a:hover { color: var(--color-white); }
  .contact-list li { font-size: 0.9rem; color: rgba(255,255,255,0.65); }

  .badge { display: inline-flex; align-items: center; padding: 0.3rem 0.75rem; border-radius: var(--radius-pill); border: 1px solid rgba(53,147,255,0.4); color: var(--color-accent); font-size: 0.8rem; font-weight: 600; width: fit-content; }

  .footer-bottom { padding-block: 1.25rem; }
  .footer-bottom-inner { display: flex; align-items: center; justify-content: space-between; gap: 1rem; flex-wrap: wrap; }
  .footer-bottom p { font-size: 0.8125rem; color: rgba(255,255,255,0.3); }

  .legal-links { display: flex; gap: 1.5rem; }
  .legal-links a { font-size: 0.8125rem; color: rgba(255,255,255,0.3); transition: color var(--transition); }
  .legal-links a:hover { color: rgba(255,255,255,0.7); }

  @media (max-width: 900px) { .footer-inner { grid-template-columns: 1fr 1fr; } }
  @media (max-width: 540px) { .footer-inner { grid-template-columns: 1fr; } .footer-bottom-inner { flex-direction: column; align-items: flex-start; } }
</style>

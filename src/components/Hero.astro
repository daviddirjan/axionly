---
interface Domain { label: string; status: string; type: 'ok' | 'warn'; }
interface Props {
  pill:     string;
  h1:       string;
  h1Accent: string;
  sub:      string;
  cta1:     string;
  cta2:     string;
  cta1Href: string;
  cta2Href: string;
  card: {
    title:   string;
    tag:     string;
    domains: Domain[];
    footer:  string;
    pages:   string;
  };
}
const { pill, h1, h1Accent, sub, cta1, cta2, cta1Href, cta2Href, card } = Astro.props;
---

<section id="hero">
  <div class="container hero-inner">

    <div class="hero-content">
      <span class="pill pill--dark">{pill}</span>
      <h1>
        {h1}
        <span class="h1-accent">{h1Accent}</span>
      </h1>
      <p class="hero-sub">{sub}</p>
      <div class="hero-actions">
        <a href={cta1Href} class="btn-hero-primary">{cta1}</a>
        <a href={cta2Href} class="btn-hero-ghost">{cta2}</a>
      </div>
    </div>

    <div class="hero-visual" aria-hidden="true">
      <div class="visual-card">
        <div class="card-top">
          <span class="card-title">{card.title}</span>
          <span class="card-tag">{card.tag}</span>
        </div>
        <div class="card-domains">
          {card.domains.map(d => (
            <div class:list={['domain', `domain--${d.type}`]}>
              <span class:list={['dot', `dot--${d.type}`]}></span>
              <span>{d.label}</span>
              <span class="domain-status">{d.status}</span>
            </div>
          ))}
        </div>
        <div class="card-footer">
          <span>{card.footer}</span>
          <span class="card-pages">{card.pages}</span>
        </div>
      </div>
      <div class="geo geo-1"></div>
      <div class="geo geo-2"></div>
      <div class="geo geo-3"></div>
    </div>

  </div>
</section>

<style>
  #hero {
    background-color: var(--color-text);
    min-height: calc(100vh - var(--header-height));
    display: flex; align-items: center;
    padding-block: var(--space-section);
    position: relative; overflow: hidden;
  }

  .hero-inner {
    display: grid; grid-template-columns: 1fr 1fr;
    gap: clamp(2.5rem, 6vw, 5rem); align-items: center;
    position: relative; z-index: 1;
  }

  .hero-content { display: flex; flex-direction: column; gap: 1.5rem; align-items: flex-start; }

  .pill--dark { background-color: rgba(53,147,255,0.15); color: var(--color-accent); border: 1px solid rgba(53,147,255,0.3); }

  h1 { color: var(--color-white); font-size: clamp(2rem, 4.5vw, 3rem); }
  .h1-accent { display: block; color: var(--color-accent); margin-top: 0.1em; }

  .hero-sub { color: rgba(255,255,255,0.7); font-size: clamp(1rem, 1.3vw, 1.0625rem); line-height: 1.75; max-width: 480px; }

  .hero-actions { display: flex; flex-wrap: wrap; gap: 0.75rem; margin-top: 0.25rem; }

  .btn-hero-primary {
    display: inline-flex; align-items: center; padding: 0.8rem 1.75rem;
    border-radius: var(--radius-pill); background-color: var(--color-accent);
    color: var(--color-white); font-weight: 700; font-size: 0.9375rem;
    transition: background-color var(--transition), transform var(--transition);
  }
  .btn-hero-primary:hover { background-color: var(--color-accent-dark); transform: translateY(-1px); }

  .btn-hero-ghost {
    display: inline-flex; align-items: center; padding: 0.8rem 1.75rem;
    border-radius: var(--radius-pill); background-color: transparent;
    color: rgba(255,255,255,0.75); font-weight: 600; font-size: 0.9375rem;
    border: 1.5px solid rgba(255,255,255,0.2);
    transition: border-color var(--transition), color var(--transition), background-color var(--transition);
  }
  .btn-hero-ghost:hover { border-color: rgba(255,255,255,0.5); color: var(--color-white); background-color: rgba(255,255,255,0.05); }

  .hero-visual { position: relative; }

  .visual-card {
    background-color: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.12);
    border-radius: var(--radius-card); padding: 1.5rem;
    backdrop-filter: blur(8px); position: relative; z-index: 2;
  }

  .card-top { display: flex; align-items: center; justify-content: space-between; margin-bottom: 1.25rem; }
  .card-title { font-weight: 700; font-size: 0.9375rem; color: var(--color-white); }
  .card-tag { font-size: 0.75rem; font-weight: 700; background-color: var(--color-accent); color: var(--color-white); padding: 0.2rem 0.65rem; border-radius: var(--radius-pill); }

  .card-domains { display: flex; flex-direction: column; gap: 0.65rem; margin-bottom: 1.25rem; }
  .domain { display: flex; align-items: center; gap: 0.6rem; font-size: 0.875rem; color: rgba(255,255,255,0.7); }
  .domain-status { margin-left: auto; font-size: 0.8rem; font-weight: 600; }
  .domain--ok  .domain-status { color: #6ee7b7; }
  .domain--warn .domain-status { color: #fcd34d; }

  .dot { width: 8px; height: 8px; border-radius: 50%; flex-shrink: 0; }
  .dot--ok   { background-color: #6ee7b7; }
  .dot--warn { background-color: #fcd34d; }

  .card-footer { display: flex; align-items: center; justify-content: space-between; font-size: 0.8125rem; color: rgba(255,255,255,0.4); border-top: 1px solid rgba(255,255,255,0.08); padding-top: 1rem; }
  .card-pages { font-weight: 600; color: rgba(255,255,255,0.5); }

  .geo { position: absolute; border-radius: 50%; border: 1.5px solid rgba(53,147,255,0.35); pointer-events: none; z-index: 1; }
  .geo-1 { width: 340px; height: 340px; top: -60px; right: -60px; background: radial-gradient(circle, rgba(53,147,255,0.07) 0%, transparent 70%); }
  .geo-2 { width: 220px; height: 220px; top: 20px; right: 20px; border-style: dashed; border-color: rgba(53,147,255,0.28); }
  .geo-3 { width: 500px; height: 500px; bottom: -180px; right: -120px; border-color: rgba(53,147,255,0.18); background: radial-gradient(circle, rgba(53,147,255,0.04) 0%, transparent 65%); }

  @media (max-width: 768px) { .hero-inner { grid-template-columns: 1fr; } .hero-visual { display: none; } h1 { font-size: clamp(1.75rem, 6vw, 2.5rem); } }
</style>

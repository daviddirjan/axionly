---
const cards = [
  {
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 5H7a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V7a2 2 0 0 0-2-2h-2"/><rect x="9" y="3" width="6" height="4" rx="1"/><line x1="9" y1="12" x2="15" y2="12"/><line x1="9" y1="16" x2="12" y2="16"/></svg>`,
    title: 'No inventory',
    body: 'Most organisations do not have a complete list of the AI tools in use across their teams. Shadow AI is widespread — tools adopted without IT or legal review.',
  },
  {
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>`,
    title: 'No compliance',
    body: 'The EU AI Act creates specific legal obligations depending on the type of AI system in use. Most organisations have not assessed their exposure or identified which systems are in scope.',
  },
  {
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>`,
    title: 'No security',
    body: 'AI systems introduce new attack surfaces: prompt injection, data leakage through third-party APIs, and uncontrolled model access. Standard IT security reviews do not cover these.',
  },
];
---

<section id="problem">
  <div class="container">
    <div class="section-header">
      <p class="section-label">The problem</p>
      <h2>Most companies are using AI.<br />Very few are managing it.</h2>
    </div>

    <ul class="cards" aria-label="Three key risk areas">
      {cards.map(card => (
        <li class="card">
          <span class="card-icon" set:html={card.icon} />
          <h3>{card.title}</h3>
          <p>{card.body}</p>
        </li>
      ))}
    </ul>
  </div>
</section>

<style>
  #problem {
    background-color: var(--color-bg);
  }

  .section-header {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    margin-bottom: clamp(2.5rem, 5vw, 4rem);
    max-width: 600px;
  }

  .cards {
    list-style: none;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.25rem;
  }

  .card {
    background-color: var(--color-container);
    border-radius: var(--radius-card);
    padding: 1.75rem;
    display: flex;
    flex-direction: column;
    gap: 0.9rem;
  }

  .card-icon {
    width: 28px;
    height: 28px;
    color: var(--color-accent);
    flex-shrink: 0;
  }

  .card-icon :global(svg) {
    width: 100%;
    height: 100%;
  }

  .card h3 {
    font-size: 1.125rem;
    font-weight: 700;
    color: var(--color-text);
  }

  .card p {
    font-size: 0.9375rem;
    color: var(--color-text-muted);
    line-height: 1.65;
  }

  @media (max-width: 768px) {
    .cards { grid-template-columns: 1fr; }
  }
</style>

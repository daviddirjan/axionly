---
const steps = [
  {
    number: '01',
    name: 'Map',
    description:
      'We inventory every AI system in use — internal tools, third-party services, and vendor integrations — to establish a complete picture.',
  },
  {
    number: '02',
    name: 'Classify',
    description:
      'We apply the EU AI Act risk classification framework to each system and identify the specific legal obligations that apply.',
  },
  {
    number: '03',
    name: 'Assess',
    description:
      'We test each system for security vulnerabilities: prompt injection, data leakage, unauthorised access, and uncontrolled vendor behaviour.',
  },
  {
    number: '04',
    name: 'Report',
    description:
      'You receive a structured report with findings, risk ratings, and a prioritised roadmap telling you exactly what to fix and in what order.',
  },
];
---

<section id="what-we-do">
  <div class="container">
    <div class="section-header">
      <p class="section-label">The engagement</p>
      <h2>Five business days.<br />One clear answer.</h2>
      <p class="intro">
        A fixed-scope engagement that gives your legal team, IT team, and leadership
        a single source of truth on your AI risk. No abstract frameworks.
        No months-long consultancies.
      </p>
    </div>

    <ol class="steps" aria-label="Audit process steps">
      {steps.map(step => (
        <li class="step-card">
          <span class="step-number" aria-hidden="true">{step.number}</span>
          <h3 class="step-name">{step.name}</h3>
          <p class="step-desc">{step.description}</p>
        </li>
      ))}
    </ol>
  </div>
</section>

<style>
  #what-we-do {
    background-color: var(--color-bg);
  }

  .section-header {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    margin-bottom: clamp(2.5rem, 5vw, 4rem);
    max-width: 600px;
  }

  .section-header h2 {
    color: var(--color-text);
  }

  .intro {
    color: var(--color-text-muted);
    line-height: 1.7;
  }

  .steps {
    list-style: none;
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.25rem;
    counter-reset: steps;
    position: relative;
  }

  /* Connecting line between cards */
  .steps::after {
    content: '';
    position: absolute;
    top: 4.25rem;
    left: calc(12.5% + 1rem);
    right: calc(12.5% + 1rem);
    height: 1px;
    background: linear-gradient(90deg, var(--color-accent) 0%, var(--color-container) 100%);
    z-index: 0;
    pointer-events: none;
  }

  .step-card {
    position: relative;
    z-index: 1;
    background-color: var(--color-container);
    border-radius: var(--radius-card);
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .step-number {
    font-family: var(--font-logo);
    font-size: 2rem;
    font-weight: 700;
    color: var(--color-accent);
    line-height: 1;
    letter-spacing: -0.03em;
  }

  .step-name {
    font-size: 1.125rem;
    font-weight: 700;
    color: var(--color-text);
  }

  .step-desc {
    font-size: 0.9rem;
    color: var(--color-text-muted);
    line-height: 1.6;
  }

  @media (max-width: 900px) {
    .steps {
      grid-template-columns: repeat(2, 1fr);
    }

    .steps::after {
      display: none;
    }
  }

  @media (max-width: 540px) {
    .steps {
      grid-template-columns: 1fr;
    }
  }
</style>

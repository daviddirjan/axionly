---
const scenarios = [
  {
    title: 'You use AI across your team — but no policy governs it.',
    body: 'Your team uses AI for hiring, content creation, or customer interactions. Nobody has formally reviewed the legal implications. You\'re not sure what obligations have already attached.',
  },
  {
    title: 'You\'re approaching an EU AI Act deadline.',
    body: 'You know the regulation is in force, but you don\'t know where your actual exposure sits. You need a clear picture before a regulator, a breach, or a legal dispute forces the issue.',
  },
  {
    title: 'Your legal team is asking questions your tech team can\'t answer.',
    body: 'There\'s a gap between what your lawyers are asking and what your engineers can explain. Axionly bridges that gap with a report both sides can read and act on.',
  },
];
---

<section id="who-we-work-with">
  <div class="container">
    <div class="section-header">
      <p class="section-label">Who we work with</p>
      <h2>You might be ready for this audit if…</h2>
      <p class="intro">
        We work with mid-size companies and enterprises across Romania and the European Union —
        organisations that are already using AI, know the regulatory environment is tightening,
        and want to get ahead of it.
      </p>
    </div>

    <ul class="scenarios" aria-label="Client scenarios">
      {scenarios.map(s => (
        <li class="scenario-card">
          <div class="scenario-stripe" aria-hidden="true"></div>
          <div class="scenario-content">
            <h3>{s.title}</h3>
            <p>{s.body}</p>
          </div>
        </li>
      ))}
    </ul>
  </div>
</section>

<style>
  #who-we-work-with {
    background-color: var(--color-bg);
  }

  .section-header {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    margin-bottom: clamp(2.5rem, 5vw, 4rem);
    max-width: 640px;
  }

  .intro {
    color: var(--color-text-muted);
    line-height: 1.7;
  }

  .scenarios {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .scenario-card {
    display: flex;
    align-items: stretch;
    border-radius: var(--radius-card);
    background-color: var(--color-white);
    border: 1.5px solid var(--color-container);
    overflow: hidden;
    transition: border-color var(--transition), box-shadow var(--transition);
  }

  .scenario-card:hover {
    border-color: var(--color-accent);
    box-shadow: 0 4px 20px rgba(53, 147, 255, 0.1);
  }

  .scenario-stripe {
    width: 4px;
    flex-shrink: 0;
    background-color: var(--color-accent);
  }

  .scenario-content {
    padding: 1.5rem 1.75rem;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }

  .scenario-content h3 {
    font-size: 1.0625rem;
    font-weight: 700;
    color: var(--color-text);
  }

  .scenario-content p {
    font-size: 0.9375rem;
    color: var(--color-text-muted);
    line-height: 1.65;
  }
</style>

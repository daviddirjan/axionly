---
interface Props { lang?: 'en' | 'ro'; }
const { lang = 'en' } = Astro.props;

const labels = {
  en: {
    col:      'What\'s included',
    standard: 'Standard',
    deepDive: 'Deep-Dive',
    features: [
      'AI System Inventory',
      'EU AI Act Gap Analysis',
      'Data Governance Review',
      'Vendor Risk Assessment',
      'Internal Policy Review',
      'Prioritised Action Plan',
      'Executive Briefing Call',
      'Prompt Injection Testing',
      'API & Access Control Review',
      'Data Leakage Risk Assessment',
      'AI Incident Response Review',
    ],
  },
  ro: {
    col:      'Ce este inclus',
    standard: 'Standard',
    deepDive: 'Analiză Aprofundată',
    features: [
      'Inventar Sisteme AI',
      'Analiză Lacune Regulament UE privind IA',
      'Revizuire Guvernanță Date',
      'Evaluare Risc Furnizori',
      'Revizuire Politică Internă',
      'Plan de Acțiune Prioritizat',
      'Apel de Prezentare Executivă',
      'Testare Injecție Prompt',
      'Revizuire API și Control Acces',
      'Evaluare Risc Scurgeri de Date',
      'Revizuire Răspuns la Incidente AI',
    ],
  },
}[lang];

const rows = labels.features.map((feature, i) => ({
  feature,
  standard: i < 7,
  deepDive: true,
}));
---

<div class="table-wrap">
  <table aria-label="Service tier comparison">
    <thead>
      <tr>
        <th scope="col">{labels.col}</th>
        <th scope="col">
          <span class="tier-name">{labels.standard}</span>
          <span class="tier-price">€1,200</span>
        </th>
        <th scope="col" class="col-highlight">
          <span class="tier-name">{labels.deepDive}</span>
          <span class="tier-price">€1,800</span>
        </th>
      </tr>
    </thead>
    <tbody>
      {rows.map(row => (
        <tr class:list={[{ 'row-deep': !row.standard }]}>
          <td>{row.feature}</td>
          <td class="cell-check">
            {row.standard
              ? <span class="yes" aria-label="Included">✓</span>
              : <span class="no"  aria-label="Not included">—</span>
            }
          </td>
          <td class="cell-check col-highlight">
            <span class="yes" aria-label="Included">✓</span>
          </td>
        </tr>
      ))}
    </tbody>
  </table>
</div>

<style>
  .table-wrap { overflow-x: auto; border-radius: var(--radius-card); border: 1.5px solid var(--color-container); }
  table { width: 100%; border-collapse: collapse; font-size: 0.9375rem; }
  thead tr { background-color: var(--color-container); }
  th { padding: 1rem 1.25rem; text-align: left; font-size: 0.875rem; }
  th:not(:first-child) { text-align: center; min-width: 130px; }
  .tier-name  { display: block; font-size: 1rem; font-weight: 700; color: var(--color-text); }
  .tier-price { display: block; font-size: 0.85rem; font-weight: 600; color: var(--color-text-muted); margin-top: 0.15rem; }
  tbody tr { border-top: 1px solid var(--color-container); background-color: var(--color-white); transition: background-color var(--transition); }
  tbody tr:hover { background-color: var(--color-bg); }
  td { padding: 0.9rem 1.25rem; color: var(--color-text-muted); }
  .cell-check { text-align: center; }
  .yes { color: var(--color-accent); font-weight: 700; font-size: 1.1rem; }
  .no  { color: #c8d8e8; font-size: 1rem; }
  .col-highlight { background-color: rgba(53,147,255,0.04); }
  thead .col-highlight { background-color: rgba(53,147,255,0.08); border-left: 2px solid var(--color-accent); }
  tbody .col-highlight { border-left: 2px solid rgba(53,147,255,0.2); }
</style>

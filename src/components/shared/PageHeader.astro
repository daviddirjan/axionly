---
interface Props {
  eyebrow?: string;
  heading: string;
  subheading?: string;
}

const { eyebrow, heading, subheading } = Astro.props;
---

<section class="page-header">
  <div class="container">
    {eyebrow && <p class="section-label">{eyebrow}</p>}
    <h1>{heading}</h1>
    {subheading && <p class="subheading">{subheading}</p>}
  </div>
</section>

<style>
  .page-header {
    background-color: var(--color-container);
    padding-block: clamp(3rem, 6vw, 5rem);
    scroll-margin-top: var(--header-height);
  }

  .container {
    max-width: 760px;
  }

  h1 {
    margin-top: 0.5rem;
    color: var(--color-text);
  }

  .subheading {
    margin-top: 1rem;
    color: var(--color-text-muted);
    font-size: clamp(1rem, 1.3vw, 1.125rem);
    line-height: 1.75;
    max-width: 640px;
  }
</style>

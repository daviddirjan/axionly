---
import BaseLayout  from '../layouts/BaseLayout.astro';
import Header      from '../components/Header.astro';
import Footer      from '../components/Footer.astro';
import PageHeader  from '../components/shared/PageHeader.astro';
import CtaBanner   from '../components/shared/CtaBanner.astro';

const credentials = [
  { label: 'AI Governance',     detail: 'Certified training in AI governance frameworks' },
  { label: 'Cybersecurity',     detail: 'Practical background in securing digital products' },
  { label: 'EU AI Act',         detail: 'Specialist knowledge of Regulation 2024/1689' },
  { label: 'ISO 42001',         detail: 'Aligned — certification in progress' },
];

const values = [
  {
    title: 'Honest findings',
    body: 'We report what we find, even when it is uncomfortable. A report that softens bad news does not protect you — it just delays the problem.',
  },
  {
    title: 'No unnecessary complexity',
    body: 'We translate regulatory and technical language into clear, plain-language findings and actions. Our clients are busy. We respect that.',
  },
  {
    title: 'Fixed scope, fixed price',
    body: 'We do not bill by the hour or expand scope mid-engagement without agreement. You know exactly what you are buying before you commit.',
  },
  {
    title: 'Confidentiality',
    body: 'All assessments are strictly confidential. We do not share client information and we do not use client names in marketing without explicit permission.',
  },
];
---

<BaseLayout
  title="About — Axionly"
  description="Axionly is a specialist AI governance and security consultancy — a division of Axiontic. We bring together legal and cybersecurity expertise in a single, structured engagement."
>
  <Header />
  <main>

    <PageHeader
      eyebrow="About"
      heading="AI governance that speaks both languages — legal and technical."
    />

    <!-- Identity -->
    <section id="identity">
      <div class="container identity-inner">
        <div class="identity-text">
          <p class="section-label">Who we are</p>
          <p>
            Axionly is a specialist AI governance and security consultancy, operating as a division
            of Axiontic — a web and digital solutions company with a track record of building
            production-grade systems for businesses across Romania and Europe.
          </p>
          <p>
            We created Axionly because we kept seeing the same gap. Companies were adopting AI
            tools rapidly — often without any formal review of the legal, security, or operational
            risks involved. And when they looked for help, they found consultants who were either
            lawyers with no technical background, or security professionals with no knowledge of
            the regulatory landscape.
          </p>
          <p>
            Axionly brings both together in a single, structured engagement.
          </p>
        </div>
        <div class="identity-stat-block">
          <div class="stat">
            <span class="stat-number">5</span>
            <span class="stat-label">business days</span>
          </div>
          <div class="stat">
            <span class="stat-number">2</span>
            <span class="stat-label">disciplines combined</span>
          </div>
          <div class="stat">
            <span class="stat-number">1</span>
            <span class="stat-label">clear report</span>
          </div>
        </div>
      </div>
    </section>

    <!-- Founder -->
    <section id="founder">
      <div class="container founder-inner">
        <div class="founder-photo-col">
          <img
            src="/team/DavidAlexandruDirjan.png"
            alt="David Alexandru Dirjan — Founder of Axionly"
            class="founder-photo"
            width="280"
            loading="eager"
          />
          <ul class="credentials" aria-label="Credentials">
            {credentials.map(c => (
              <li class="credential">
                <span class="cred-label">{c.label}</span>
                <span class="cred-detail">{c.detail}</span>
              </li>
            ))}
          </ul>
        </div>
        <div class="founder-text">
          <p class="section-label">The founder</p>
          <h2>Every assessment is personally led and reviewed.</h2>
          <p>
            David Alexandru Dirjan is the founder of Axionly and lead consultant on all assessments.
            With a background in web development, cybersecurity, and AI governance, Axionly
            was founded to help organisations navigate the intersection of AI adoption and
            regulatory compliance.
          </p>
          <p>
            With specialist training in AI governance and practical cybersecurity knowledge
            from years of building and securing digital products for clients across Romania
            and the European Union, every assessment is personally led and reviewed.
            Axionly does not outsource its work.
          </p>
          <a
            href="https://www.linkedin.com/in/david-dirjan-3573561b3/"
            target="_blank"
            rel="noopener"
            class="linkedin-link"
            aria-label="Connect on LinkedIn"
          >
            <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
            </svg>
            Connect on LinkedIn
          </a>
        </div>
      </div>
    </section>

    <!-- Axiontic connection -->
    <section id="axiontic">
      <div class="container axiontic-inner">
        <div class="axiontic-text">
          <p class="section-label">Our foundation</p>
          <h2>Rooted in real technology, not just compliance theory.</h2>
          <p>
            Axionly is a division of Axiontic, a web and digital development company that
            builds production-grade applications for businesses. This technical foundation
            matters. Our understanding of AI risk is grounded in how these systems are
            actually built, integrated, and exposed — not just what the regulatory text
            says about them.
          </p>
          <a
            href="https://axiontic.com"
            target="_blank"
            rel="noopener"
            class="btn-ghost axiontic-btn"
          >
            Learn more about Axiontic →
          </a>
        </div>
        <div class="axiontic-card" aria-hidden="true">
          <div class="ac-logo">Axiontic</div>
          <div class="ac-divider"></div>
          <div class="ac-division">
            <span class="ac-div-label">Division</span>
            <span class="ac-div-name">Axionly<span class="dot">.</span></span>
          </div>
          <p class="ac-desc">AI Governance &amp; Security Consulting</p>
        </div>
      </div>
    </section>

    <!-- Values -->
    <section id="values">
      <div class="container">
        <div class="values-header">
          <p class="section-label">How we work</p>
          <h2>Four principles we do not compromise on.</h2>
        </div>
        <ul class="values-grid" aria-label="Working principles">
          {values.map(v => (
            <li class="value-card">
              <h3>{v.title}</h3>
              <p>{v.body}</p>
            </li>
          ))}
        </ul>
      </div>
    </section>

    <CtaBanner
      heading="Work with a team that understands both sides."
      subtext="Book a free 20-minute discovery call. We will listen, ask the right questions, and tell you honestly what an assessment would find."
    />

  </main>
  <Footer />
</BaseLayout>

<style>
  /* ── Identity ── */
  #identity {
    background-color: var(--color-bg);
    padding-block: var(--space-section);
  }

  .identity-inner {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: clamp(3rem, 6vw, 6rem);
    align-items: start;
  }

  .identity-text {
    display: flex;
    flex-direction: column;
    gap: 1.1rem;
    max-width: 640px;
  }

  .identity-text p {
    color: var(--color-text-muted);
    line-height: 1.75;
    font-size: clamp(1rem, 1.2vw, 1.0625rem);
  }

  .identity-stat-block {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    background-color: var(--color-container);
    border-radius: var(--radius-card);
    padding: 2rem;
    min-width: 180px;
    text-align: center;
  }

  .stat {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }

  .stat-number {
    font-family: var(--font-logo);
    font-size: 3rem;
    font-weight: 700;
    color: var(--color-accent);
    line-height: 1;
    letter-spacing: -0.03em;
  }

  .stat-label {
    font-size: 0.8rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-text-muted);
  }

  /* ── Founder ── */
  #founder {
    background-color: var(--color-container);
    padding-block: var(--space-section);
  }

  .founder-inner {
    display: grid;
    grid-template-columns: 280px 1fr;
    gap: clamp(2.5rem, 5vw, 5rem);
    align-items: start;
  }

  .founder-photo-col {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .founder-photo {
    width: 100%;
    aspect-ratio: 3/4;
    object-fit: cover;
    object-position: center top;
    border-radius: var(--radius-card);
    display: block;
  }

  .credentials {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .credential {
    background-color: var(--color-white);
    border-radius: var(--radius-sm);
    padding: 0.65rem 0.9rem;
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
  }

  .cred-label {
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-accent);
  }

  .cred-detail {
    font-size: 0.825rem;
    color: var(--color-text-muted);
  }

  .founder-text {
    display: flex;
    flex-direction: column;
    gap: 1.1rem;
    padding-top: 0.25rem;
  }

  .founder-text h2 {
    font-size: clamp(1.3rem, 2.5vw, 1.9rem);
    color: var(--color-text);
  }

  .founder-text p {
    color: var(--color-text-muted);
    line-height: 1.75;
  }

  .linkedin-link {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    color: var(--color-accent);
    font-weight: 600;
    font-size: 0.9375rem;
    margin-top: 0.5rem;
    transition: opacity var(--transition);
  }

  .linkedin-link svg {
    width: 20px;
    height: 20px;
  }

  .linkedin-link:hover { opacity: 0.75; }

  /* ── Axiontic ── */
  #axiontic {
    background-color: var(--color-bg);
    padding-block: var(--space-section);
  }

  .axiontic-inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(2.5rem, 6vw, 5rem);
    align-items: center;
  }

  .axiontic-text {
    display: flex;
    flex-direction: column;
    gap: 1.1rem;
  }

  .axiontic-text h2 {
    font-size: clamp(1.3rem, 2.5vw, 1.9rem);
    color: var(--color-text);
  }

  .axiontic-text p {
    color: var(--color-text-muted);
    line-height: 1.75;
  }

  .axiontic-btn {
    align-self: flex-start;
    margin-top: 0.5rem;
  }

  .axiontic-card {
    background-color: var(--color-container);
    border-radius: var(--radius-card);
    padding: 2rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .ac-logo {
    font-family: var(--font-logo);
    font-weight: 700;
    font-size: 1.5rem;
    color: var(--color-text);
    letter-spacing: -0.03em;
  }

  .ac-divider {
    height: 1px;
    background-color: rgba(0, 28, 59, 0.12);
  }

  .ac-division {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }

  .ac-div-label {
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-text-muted);
  }

  .ac-div-name {
    font-family: var(--font-logo);
    font-size: 1.75rem;
    font-weight: 700;
    color: var(--color-text);
    letter-spacing: -0.04em;
  }

  .dot { color: var(--color-accent); }

  .ac-desc {
    font-size: 0.875rem;
    color: var(--color-text-muted);
  }

  /* ── Values ── */
  #values {
    background-color: var(--color-container);
    padding-block: var(--space-section);
  }

  .values-header {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    margin-bottom: 2.5rem;
    max-width: 500px;
  }

  .values-header h2 {
    font-size: clamp(1.3rem, 2.5vw, 1.9rem);
    color: var(--color-text);
  }

  .values-grid {
    list-style: none;
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.25rem;
  }

  .value-card {
    background-color: var(--color-white);
    border-radius: var(--radius-card);
    padding: 1.75rem;
    display: flex;
    flex-direction: column;
    gap: 0.65rem;
  }

  .value-card h3 {
    font-size: 1.0625rem;
    font-weight: 700;
    color: var(--color-text);
  }

  .value-card p {
    font-size: 0.9375rem;
    color: var(--color-text-muted);
    line-height: 1.65;
  }

  /* ── Responsive ── */
  @media (max-width: 900px) {
    .identity-inner     { grid-template-columns: 1fr; }
    .founder-inner      { grid-template-columns: 1fr; }
    .axiontic-inner     { grid-template-columns: 1fr; }
    .identity-stat-block { flex-direction: row; justify-content: space-around; }
    .founder-photo-col  { max-width: 280px; }
  }

  @media (max-width: 540px) {
    .values-grid { grid-template-columns: 1fr; }
  }
</style>

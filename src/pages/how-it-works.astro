---
import BaseLayout  from '../layouts/BaseLayout.astro';
import Header      from '../components/Header.astro';
import Footer      from '../components/Footer.astro';
import PageHeader  from '../components/shared/PageHeader.astro';
import CtaBanner   from '../components/shared/CtaBanner.astro';

const steps = [
  {
    number: '01',
    name: 'Discovery Call',
    tag: 'Day 0 — Free, no commitment',
    duration: '20 minutes',
    what: 'We have a brief conversation to understand your organisation, what AI tools you use, and what concerns or questions you have. We confirm whether an assessment is the right fit. You ask us anything. If we proceed, we agree on scope and confirm the start date.',
    fromYou: 'Nothing in advance. Just a 20-minute slot in your calendar.',
  },
  {
    number: '02',
    name: 'Scoping & Onboarding',
    tag: 'Day 1',
    duration: '60-minute call',
    what: 'We conduct a structured scoping call with the relevant people in your organisation — typically IT, legal, and one business lead. We define the systems in scope, agree on a point of contact, and collect any available documents such as existing policies, vendor contracts, and tool lists.',
    fromYou: 'A list of AI tools in use if one exists, any existing AI or data governance policies, and availability of 2–3 stakeholders for short interviews.',
  },
  {
    number: '03',
    name: 'Assessment',
    tag: 'Days 2–4',
    duration: '3 working days',
    what: 'We conduct the full assessment independently. This includes document review, short stakeholder interviews (30 minutes each, conducted remotely), regulatory mapping, and — for the Security Deep-Dive tier — technical review of AI systems and APIs. We do not require extended access to your team during this phase.',
    fromYou: 'Availability for short interviews (scheduled in advance). Access to relevant documents via secure file sharing. For the Security Deep-Dive: read-only access to API configurations where applicable.',
  },
  {
    number: '04',
    name: 'Report & Briefing',
    tag: 'Day 5',
    duration: 'Report delivered by end of day + 30-minute call',
    what: 'You receive the full written report in PDF format. We then hold a 30-minute briefing call with your leadership or compliance team to walk through findings, answer questions, and confirm ownership of each action item.',
    fromYou: 'A 30-minute slot for key stakeholders. The report is yours to keep, share internally, and act on.',
  },
];

const faqs = [
  {
    q: 'Do we need to give you access to our systems?',
    a: 'For the standard assessment, no. We work from documents, interviews, and publicly available information about your AI tools. For the Security Deep-Dive, we may request read-only access to specific API configurations — agreed in advance and nothing is accessed without explicit written permission.',
  },
  {
    q: 'How much of our team\'s time does this require?',
    a: 'Minimal. Beyond the two calls (scoping and briefing), we typically need 30 minutes each from 2–3 people for structured interviews. Total time commitment from your side is approximately 3–4 hours across the full engagement.',
  },
  {
    q: 'What if we only use common tools like ChatGPT or Microsoft Copilot?',
    a: 'Those tools are precisely what we assess. Many organisations assume that using widely-adopted AI tools means no compliance risk. The EU AI Act creates obligations based on how you use AI, not just which tools you use. We assess your use case, the data involved, and the controls around it.',
  },
  {
    q: 'Is this a one-time engagement or ongoing?',
    a: 'The assessment itself is a one-time, fixed-scope engagement. We do offer optional follow-on services including quarterly governance reviews and policy drafting, but there is no obligation to continue after the initial report.',
  },
  {
    q: 'Do you work with companies outside Romania?',
    a: 'Yes. All engagements are conducted remotely. We work with organisations across the European Union and the assessment covers EU regulatory requirements regardless of where in the EU the client is based.',
  },
];

const reportSections = [
  { num: '01', title: 'Executive Summary',      desc: 'Overall AI readiness rating with key findings at a glance.' },
  { num: '02', title: 'AI System Inventory',    desc: 'Complete register of AI tools with EU AI Act risk classification for each.' },
  { num: '03', title: 'Regulatory Gap Analysis', desc: 'Obligations identified, articles cited, gaps mapped.' },
  { num: '04', title: 'Risk Assessment',         desc: 'Findings by domain — legal, data governance, vendor, policy.' },
  { num: '05', title: 'Security Findings',       desc: 'Deep-Dive tier only: vulnerabilities, attack surface, technical recommendations.' },
  { num: '06', title: 'Prioritised Action Plan', desc: 'Immediate, 30-day, and 90-day actions — each with an owner and risk rating.' },
];
---

<BaseLayout
  title="How It Works — Axionly"
  description="Simple, structured, and finished in five days. Here is exactly what happens from the moment you contact Axionly to the moment you receive your AI risk report."
>
  <Header />
  <main>

    <PageHeader
      eyebrow="How It Works"
      heading="Simple, structured, and finished in five days."
      subheading="Here is exactly what happens from the moment you contact us to the moment you receive your report."
    />

    <!-- Four steps -->
    <section id="steps">
      <div class="container">
        <ol class="steps-list" aria-label="Engagement process">
          {steps.map((step, i) => (
            <li class="step-item">
              <div class="step-left">
                <span class="step-number" aria-hidden="true">{step.number}</span>
                {i < steps.length - 1 && <span class="step-line" aria-hidden="true"></span>}
              </div>
              <div class="step-body">
                <div class="step-meta">
                  <h2 class="step-name">{step.name}</h2>
                  <span class="step-tag">{step.tag}</span>
                </div>
                <p class="step-duration">Duration: <strong>{step.duration}</strong></p>
                <div class="step-details">
                  <div class="detail-block">
                    <p class="detail-label">What happens</p>
                    <p>{step.what}</p>
                  </div>
                  <div class="detail-block detail-block--accent">
                    <p class="detail-label">What we need from you</p>
                    <p>{step.fromYou}</p>
                  </div>
                </div>
              </div>
            </li>
          ))}
        </ol>
      </div>
    </section>

    <!-- Report structure -->
    <section id="report-structure">
      <div class="container">
        <div class="report-header">
          <p class="section-label">The deliverable</p>
          <h2>What the report looks like</h2>
          <p class="report-intro">
            A professional, confidential PDF — typically 20–35 pages depending on scope.
            Six structured sections, every finding tied to a specific action and risk rating.
          </p>
        </div>
        <ul class="report-sections" aria-label="Report structure">
          {reportSections.map(s => (
            <li class="report-section">
              <span class="rs-num" aria-hidden="true">{s.num}</span>
              <div>
                <h3>{s.title}</h3>
                <p>{s.desc}</p>
              </div>
            </li>
          ))}
        </ul>
      </div>
    </section>

    <!-- FAQ -->
    <section id="faq">
      <div class="container faq-inner">
        <div class="faq-header">
          <p class="section-label">Common questions</p>
          <h2>Before you reach out</h2>
        </div>
        <dl class="faq-list">
          {faqs.map(item => (
            <div class="faq-item">
              <dt>{item.q}</dt>
              <dd>{item.a}</dd>
            </div>
          ))}
        </dl>
      </div>
    </section>

    <CtaBanner
      heading="Ready to see the process in action?"
      subtext="Book a free 20-minute discovery call. We will walk you through exactly what the assessment would cover for your organisation."
    />

  </main>
  <Footer />
</BaseLayout>

<style>
  /* ── Steps ── */
  #steps {
    background-color: var(--color-bg);
    padding-block: var(--space-section);
  }

  .steps-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .step-item {
    display: flex;
    gap: 2rem;
    padding-bottom: 3rem;
  }

  .step-item:last-child {
    padding-bottom: 0;
  }

  /* Left column: number + connecting line */
  .step-left {
    display: flex;
    flex-direction: column;
    align-items: center;
    flex-shrink: 0;
    width: 48px;
  }

  .step-number {
    width: 48px;
    height: 48px;
    border-radius: 50%;
    background-color: var(--color-accent);
    color: var(--color-white);
    font-family: var(--font-logo);
    font-size: 1.1rem;
    font-weight: 700;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    letter-spacing: -0.02em;
  }

  .step-line {
    width: 2px;
    flex: 1;
    background: linear-gradient(to bottom, var(--color-accent), var(--color-container));
    margin-top: 0.5rem;
    min-height: 40px;
  }

  /* Right column: content */
  .step-body {
    flex: 1;
    padding-top: 0.6rem;
    display: flex;
    flex-direction: column;
    gap: 0.9rem;
    padding-bottom: 1rem;
  }

  .step-meta {
    display: flex;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .step-name {
    font-size: clamp(1.15rem, 2vw, 1.4rem);
    font-weight: 700;
    color: var(--color-text);
  }

  .step-tag {
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--color-accent);
    background-color: var(--color-container);
    padding: 0.2rem 0.75rem;
    border-radius: var(--radius-pill);
    letter-spacing: 0.02em;
  }

  .step-duration {
    font-size: 0.9rem;
    color: var(--color-text-muted);
  }

  .step-duration strong {
    color: var(--color-text);
  }

  .step-details {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
    margin-top: 0.25rem;
  }

  .detail-block {
    background-color: var(--color-container);
    border-radius: var(--radius-card);
    padding: 1.25rem;
    font-size: 0.9375rem;
    color: var(--color-text-muted);
    line-height: 1.65;
  }

  .detail-block--accent {
    border-left: 3px solid var(--color-accent);
  }

  .detail-label {
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--color-text-muted);
    margin-bottom: 0.5rem;
  }

  /* ── Report structure ── */
  #report-structure {
    background-color: var(--color-container);
    padding-block: var(--space-section);
  }

  .report-header {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    margin-bottom: 2.5rem;
    max-width: 560px;
  }

  .report-intro {
    color: var(--color-text-muted);
    line-height: 1.7;
  }

  .report-sections {
    list-style: none;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
  }

  .report-section {
    background-color: var(--color-white);
    border-radius: var(--radius-card);
    padding: 1.25rem 1.5rem;
    display: flex;
    gap: 1rem;
    align-items: flex-start;
  }

  .rs-num {
    font-family: var(--font-logo);
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--color-accent);
    letter-spacing: -0.02em;
    flex-shrink: 0;
    line-height: 1.2;
  }

  .report-section h3 {
    font-size: 0.9375rem;
    font-weight: 700;
    color: var(--color-text);
    margin-bottom: 0.3rem;
  }

  .report-section p {
    font-size: 0.875rem;
    color: var(--color-text-muted);
    line-height: 1.55;
  }

  /* ── FAQ ── */
  #faq {
    background-color: var(--color-bg);
    padding-block: var(--space-section);
  }

  .faq-inner {
    display: grid;
    grid-template-columns: 280px 1fr;
    gap: clamp(2rem, 5vw, 5rem);
    align-items: start;
  }

  .faq-header {
    position: sticky;
    top: calc(var(--header-height) + 2rem);
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .faq-header h2 {
    font-size: clamp(1.3rem, 2.5vw, 1.75rem);
    color: var(--color-text);
  }

  .faq-list {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .faq-item {
    border-bottom: 1px solid var(--color-container);
    padding-block: 1.5rem;
  }

  .faq-item:first-child {
    border-top: 1px solid var(--color-container);
  }

  .faq-item dt {
    font-size: 1rem;
    font-weight: 700;
    color: var(--color-text);
    margin-bottom: 0.65rem;
  }

  .faq-item dd {
    font-size: 0.9375rem;
    color: var(--color-text-muted);
    line-height: 1.7;
    margin: 0;
  }

  /* ── Responsive ── */
  @media (max-width: 900px) {
    .report-sections { grid-template-columns: repeat(2, 1fr); }
    .faq-inner { grid-template-columns: 1fr; }
    .faq-header { position: static; }
  }

  @media (max-width: 640px) {
    .step-details { grid-template-columns: 1fr; }
    .report-sections { grid-template-columns: 1fr; }
    .step-left { display: none; }
  }
</style>

---
import BaseLayout  from '../../layouts/BaseLayout.astro';
import Header      from '../../components/Header.astro';
import Footer      from '../../components/Footer.astro';
import PageHeader  from '../../components/shared/PageHeader.astro';
---

<BaseLayout
  title="Contact — Axionly"
  description="Rezervați un apel de descoperire gratuit de 20 de minute cu Axionly. Fără angajament, fără jargon — doar o conversație sinceră despre riscul dumneavoastră AI."
  htmlLang="ro"
>
  <Header />
  <main>

    <PageHeader
      eyebrow="Contact"
      heading="Să vorbim despre riscul dumneavoastră AI."
      subheading="Rezervați un apel de descoperire gratuit de 20 de minute. Fără angajament, fără jargon. Vă vom spune sincer dacă o evaluare are sens pentru organizația dumneavoastră."
    />

    <section id="contact-main">
      <div class="container contact-grid">

        <!-- Stânga: rezervare + detalii de contact -->
        <div class="contact-left">

          <!-- Bloc rezervare -->
          <div class="booking-block">
            <p class="block-label">Rezervați un apel</p>
            <h2>Apel de Descoperire Gratuit — 20 de minute</h2>
            <p class="booking-desc">
              Selectați un interval orar care vă convine. După rezervare veți primi un
              email de confirmare și o invitație de calendar cu un link pentru întâlnire.
            </p>
            <div class="calendar-placeholder" aria-label="Widget de rezervare calendar">
              <div class="calendar-icon" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                  <rect x="3" y="4" width="18" height="18" rx="2"/>
                  <line x1="16" y1="2" x2="16" y2="6"/>
                  <line x1="8" y1="2" x2="8" y2="6"/>
                  <line x1="3" y1="10" x2="21" y2="10"/>
                </svg>
              </div>
              <p class="cal-title">Widget Calendly / Cal.com</p>
              <p class="cal-sub">
                Înlocuiți acest bloc cu widget-ul dumneavoastră de rezervare integrat.
              </p>
              <a
                href="mailto:hello@axionly.io?subject=Solicitare Apel de Descoperire"
                class="btn-primary cal-btn"
              >
                Solicitați un apel prin email
              </a>
            </div>
          </div>

          <!-- Detalii de contact -->
          <div class="contact-details">
            <dl class="details-list">
              <div class="detail-row">
                <dt>
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
                    <polyline points="22,6 12,13 2,6"/>
                  </svg>
                  Email
                </dt>
                <dd><a href="mailto:hello@axionly.io">hello@axionly.io</a></dd>
              </div>
              <div class="detail-row">
                <dt>
                  <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                    <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
                  </svg>
                  LinkedIn
                </dt>
                <dd><a href="https://linkedin.com" target="_blank" rel="noopener">Conectați-vă pe LinkedIn</a></dd>
              </div>
              <div class="detail-row">
                <dt>
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <circle cx="12" cy="12" r="10"/>
                    <line x1="2" y1="12" x2="22" y2="12"/>
                    <path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/>
                  </svg>
                  Locație
                </dt>
                <dd>Oradea, BH, România, UE</dd>
              </div>
              <div class="detail-row">
                <dt>
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <rect x="2" y="3" width="20" height="14" rx="2"/>
                    <line x1="8" y1="21" x2="16" y2="21"/>
                    <line x1="12" y1="17" x2="12" y2="21"/>
                  </svg>
                  Companie
                </dt>
                <dd>Axionly — o divizie a <a href="https://axiontic.com" target="_blank" rel="noopener">Axiontic</a></dd>
              </div>
            </dl>
          </div>

        </div>

        <!-- Dreapta: formular de contact + text de încredere -->
        <div class="contact-right">

          <div class="form-block">
            <p class="block-label">Trimiteți un mesaj</p>
            <h2>Preferați să scrieți mai întâi?</h2>
            <p class="form-desc">
              Nu sunteți gata să rezervați un apel încă? Trimiteți-ne un mesaj și vă vom răspunde în maximum o zi lucrătoare.
            </p>
            <form class="contact-form" method="POST" novalidate aria-label="Formular de contact">
              <div class="field-row">
                <div class="field">
                  <label for="fullName">Nume complet <span aria-hidden="true">*</span></label>
                  <input
                    type="text"
                    id="fullName"
                    name="fullName"
                    autocomplete="name"
                    required
                    aria-required="true"
                    placeholder="Ion Popescu"
                  />
                </div>
                <div class="field">
                  <label for="company">Numele companiei <span aria-hidden="true">*</span></label>
                  <input
                    type="text"
                    id="company"
                    name="company"
                    autocomplete="organization"
                    required
                    aria-required="true"
                    placeholder="Firma SA"
                  />
                </div>
              </div>
              <div class="field">
                <label for="email">Adresă de email de serviciu <span aria-hidden="true">*</span></label>
                <input
                  type="email"
                  id="email"
                  name="email"
                  autocomplete="email"
                  required
                  aria-required="true"
                  placeholder="ion@companie.ro"
                />
              </div>
              <div class="field">
                <label for="message">Mesajul dumneavoastră</label>
                <textarea
                  id="message"
                  name="message"
                  rows="5"
                  placeholder="Descrieți pe scurt ce instrumente AI utilizează organizația dumneavoastră și ce întrebări aveți."
                ></textarea>
              </div>
              <button type="submit" class="btn-primary submit-btn">Trimiteți Mesajul</button>
            </form>
          </div>

          <!-- Bloc de încredere -->
          <div class="trust-block" role="note">
            <svg class="trust-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
            </svg>
            <p>
              Apelul de descoperire este cu adevărat gratuit și nu implică nicio obligație. Vom asculta
              situația dumneavoastră, vă vom spune ce am evalua și vă vom oferi o opinie sinceră
              dacă serviciul nostru ar fi util. Dacă nu este potrivit pentru dumneavoastră, vă vom spune —
              și vom sugera ce ar putea fi.
            </p>
          </div>

        </div>
      </div>
    </section>

  </main>
  <Footer />
</BaseLayout>

<style>
  #contact-main {
    background-color: var(--color-bg);
    padding-block: var(--space-section);
  }

  .contact-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(2.5rem, 5vw, 5rem);
    align-items: start;
  }

  /* ── Comun ── */
  .block-label {
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-accent);
    margin-bottom: 0.5rem;
  }

  .contact-left,
  .contact-right {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  /* ── Bloc rezervare ── */
  .booking-block {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .booking-block h2 {
    font-size: clamp(1.2rem, 2vw, 1.5rem);
    color: var(--color-text);
  }

  .booking-desc {
    color: var(--color-text-muted);
    line-height: 1.7;
    font-size: 0.9375rem;
  }

  .calendar-placeholder {
    background-color: var(--color-container);
    border: 2px dashed rgba(53, 147, 255, 0.35);
    border-radius: var(--radius-card);
    padding: 2.5rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 0.75rem;
    margin-top: 0.5rem;
  }

  .calendar-icon {
    width: 48px;
    height: 48px;
    color: var(--color-accent);
    opacity: 0.6;
  }

  .calendar-icon svg { width: 100%; height: 100%; }

  .cal-title {
    font-size: 1rem;
    font-weight: 700;
    color: var(--color-text);
  }

  .cal-sub {
    font-size: 0.875rem;
    color: var(--color-text-muted);
    max-width: 260px;
    line-height: 1.5;
  }

  .cal-btn {
    margin-top: 0.5rem;
  }

  /* ── Detalii de contact ── */
  .contact-details {
    background-color: var(--color-container);
    border-radius: var(--radius-card);
    padding: 1.5rem;
  }

  .details-list {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .detail-row {
    display: flex;
    align-items: flex-start;
    gap: 1rem;
  }

  .detail-row dt {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.8125rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-text-muted);
    min-width: 100px;
    flex-shrink: 0;
    margin: 0;
  }

  .detail-row dt svg {
    width: 16px;
    height: 16px;
    flex-shrink: 0;
  }

  .detail-row dd {
    font-size: 0.9375rem;
    color: var(--color-text);
    margin: 0;
    line-height: 1.5;
  }

  .detail-row dd a {
    color: var(--color-accent);
    font-weight: 500;
    transition: opacity var(--transition);
  }

  .detail-row dd a:hover { opacity: 0.75; }

  /* ── Bloc formular ── */
  .form-block {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .form-block h2 {
    font-size: clamp(1.2rem, 2vw, 1.5rem);
    color: var(--color-text);
  }

  .form-desc {
    color: var(--color-text-muted);
    font-size: 0.9375rem;
    line-height: 1.65;
  }

  .contact-form {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    margin-top: 0.5rem;
  }

  .field-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.75rem;
  }

  .field {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .field label {
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--color-text);
  }

  .field label span {
    color: var(--color-accent);
  }

  .field input,
  .field textarea {
    padding: 0.75rem 1rem;
    border: 1.5px solid var(--color-container);
    border-radius: var(--radius-card);
    font-family: var(--font-body);
    font-size: 0.9375rem;
    color: var(--color-text);
    background-color: var(--color-white);
    transition: border-color var(--transition);
    outline: none;
    resize: vertical;
  }

  .field input:focus,
  .field textarea:focus {
    border-color: var(--color-accent);
  }

  .field input::placeholder,
  .field textarea::placeholder {
    color: var(--color-text-muted);
    opacity: 0.6;
  }

  .submit-btn {
    align-self: flex-start;
  }

  /* ── Bloc de încredere ── */
  .trust-block {
    background-color: var(--color-container);
    border-radius: var(--radius-card);
    padding: 1.5rem;
    display: flex;
    gap: 1rem;
    align-items: flex-start;
  }

  .trust-icon {
    width: 24px;
    height: 24px;
    color: var(--color-accent);
    flex-shrink: 0;
    margin-top: 0.1em;
  }

  .trust-block p {
    font-size: 0.9rem;
    color: var(--color-text-muted);
    line-height: 1.7;
    font-style: italic;
  }

  /* ── Responsive ── */
  @media (max-width: 900px) {
    .contact-grid { grid-template-columns: 1fr; }
  }

  @media (max-width: 540px) {
    .field-row { grid-template-columns: 1fr; }
  }
</style>
